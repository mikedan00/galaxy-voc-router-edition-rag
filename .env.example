# Galaxy VOC Collector — Router Edition
# cp .env.example .env 후 값을 채우세요.

# 실행 모드: hf_api 권장. local은 GPU/대용량 모델 설치가 필요합니다.
LLM_ENGINE=hf_api

# Hugging Face token. 실제 토큰은 절대 GitHub에 올리지 마세요.
HF_TOKEN=hf_replace_me

# HF Router 기본 모델. provider suffix를 명시하는 것을 권장합니다.
HF_ROUTER_MODEL=google/gemma-4-26B-A4B-it:deepinfra

# Fallback 후보. 쉼표 구분, 따옴표 없이 한 줄로 둡니다.
HF_MODEL_CANDIDATES=google/gemma-4-26B-A4B-it:deepinfra,google/gemma-4-26B-A4B-it:novita,google/gemma-4-31B-it:deepinfra,google/gemma-4-31B-it:together,Qwen/Qwen3.5-9B:together,Qwen/Qwen2.5-7B-Instruct:together

# 생성 설정
HF_MAX_TOKENS=1400
HF_TEMPERATURE=0.2

# 네트워크/재시도
HF_TIMEOUT_CONNECT=10
HF_TIMEOUT_READ=120
HF_MAX_RETRIES=3

# local mode 옵션
USE_4BIT=true
USE_GPU=true

# Streamlit port
PORT=8501
